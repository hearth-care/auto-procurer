# Copy these keys into the deployment environment. Values are intentionally
# placeholders; do not commit project ids, bucket names, service-account emails,
# or scheduler target URIs.
XSOURCE_CLOUD_RUN_PROJECT=
XSOURCE_CLOUD_RUN_REGION=
XSOURCE_ARTIFACT_REPOSITORY=
XSOURCE_IMAGE_NAME=xsource
XSOURCE_RUNTIME_SERVICE_ACCOUNT=

XSOURCE_WATCHER_JOB_NAME=
XSOURCE_SYNC_JOB_NAME=
XSOURCE_SIGNALS_JOB_NAME=

XSOURCE_WATCHER_SCHEDULER_NAME=
XSOURCE_SYNC_SCHEDULER_NAME=
XSOURCE_SIGNALS_SCHEDULER_NAME=

XSOURCE_WATCHER_SCHEDULE=*/5 * * * *
XSOURCE_SYNC_SCHEDULE=10 2 * * *
XSOURCE_SIGNALS_SCHEDULE=5 7 * * *
XSOURCE_SCHEDULER_TIME_ZONE=Europe/London

XSOURCE_EMIT_SIGNALS=1
XSOURCE_RUNTIME_ENV=cloud-run
